[Unit]
Description=Arche GPU noise suppression (Maxine denoiser)
After=pipewire.service pipewire-session-manager.service
BindsTo=pipewire.service
ConditionPathExists=%h/.local/share/arche-denoise/lib/libnv_audiofx.so

[Service]
Type=simple
Environment=LD_LIBRARY_PATH=%h/.local/share/arche-denoise/lib
ExecStart=%h/.local/bin/arche/arche-denoise
Restart=on-failure
RestartSec=3
TimeoutStartSec=30
StandardError=journal

[Install]
WantedBy=pipewire.service
