#!/usr/bin/env bash
# arche-popup — launch a TUI app as a centered floating popup
# Usage: arche-popup <command> [args...]
#
# Convention: kitty --class popup triggers hyprland window rules
# (float, center, sized). Change this one script to change it everywhere.

set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "Usage: arche-popup <command> [args...]" >&2
    exit 1
fi

exec uwsm-app -- kitty --class popup -e "$@"
