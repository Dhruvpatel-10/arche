#!/usr/bin/env bash
# arche-screenshot — freeze → dim → select → capture → edit

set -euo pipefail

# Single-instance lock. flock is kernel-held, so it's released automatically
# when the script exits — including on SIGKILL or a crash. The older
# PID-file + `kill -0` check left the lock held forever if the script hung
# instead of crashing (e.g. grim blocked on a DMA fence — see below), so
# SUPER+S silently no-op'd until the lockfile was removed by hand.
SCREENSHOT_LOCK="${XDG_RUNTIME_DIR:-/tmp}/arche-screenshot.lock"
exec 200>"$SCREENSHOT_LOCK"
flock -n 200 || exit 0

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
dir="$HOME/Pictures/Screenshots"
mkdir -p "$dir"
f="$dir/$(date +%Y%m%d_%H%M%S).png"

# Freeze screen — PID-based for clean lifecycle control
"$SCRIPT_DIR/wayfreeze" --hide-cursor &
freeze_pid=$!
sleep 0.1

# Single EXIT trap — cleans both freeze process and lockfile, on any path.
cleanup() {
    kill "$freeze_pid" 2>/dev/null
    wait "$freeze_pid" 2>/dev/null || true
    rm -f "$SCREENSHOT_LOCK"
}
trap cleanup EXIT

# Region select on frozen frame
# Dark overlay signals "screenshot mode" (like Windows/KDE dim effect)
geometry=$(slurp -d \
    -b 00000066 \
    -c c9943eff \
    -s c9943e18 \
    -B 00000066 \
    -w 2) || exit 0

# Capture from frozen frame. `timeout` guards against grim blocking
# indefinitely on a DMA fence (observed with Hyprland + NVIDIA + wlr
# screencopy) — without it a hang would leave wayfreeze on screen and
# the flock held until the process was killed by hand. grim normally
# finishes in well under a second; 10s is generous enough to absorb
# a slow frame without being user-visible when things misbehave.
timeout 10s grim -l 0 -s 1 -g "$geometry" "$f" || exit 0

# Unfreeze immediately — don't wait for clipboard/notification
cleanup
trap - EXIT

# Copy to clipboard — setsid -f detaches wl-copy into its own session so it
# survives after this script (and its systemd scope) exit. Without this, the
# wl-copy daemon that holds the clipboard selection gets reaped along with
# the script, and the image silently disappears from the clipboard.
setsid -f wl-copy --type image/png < "$f"

# Notify + handle Edit action in a detached subshell. notify-send -A blocks
# until the user clicks an action (or the notification times out) — we don't
# want this script to hang around waiting, both to keep things clean and so
# repeated screenshots don't pile up stale processes.
setsid -f bash -c '
    action=$(notify-send -i "$1" \
        -a "Screenshot" \
        -A "edit=Edit" \
        "Screenshot copied" \
        "$(basename "$1")")
    if [[ "$action" == "edit" ]]; then
        satty --filename "$1" \
            --output-filename "$1" \
            --copy-command "wl-copy --type image/png" \
            2>/dev/null
    fi
' _ "$f" </dev/null >/dev/null 2>&1
