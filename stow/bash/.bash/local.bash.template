#!/usr/bin/env bash
# Secrets — copy this file to ~/.bash/local.bash and fill in real values.
# local.bash is gitignored and must never be committed.
#
# Leading-space trick does NOT hide commands here: bash-preexec rewrites
# HISTCONTROL=ignorespace to ignoredups at load time (see docs/decisions.md D016).
# Put secrets in files, not command lines.

export GEMINI_API_KEY=YOUR_KEY_HERE
export OPENAI_API_KEY=YOUR_KEY_HERE
export GROQ_API_KEY=YOUR_KEY_HERE
export ANTHROPIC_API_KEY=YOUR_KEY_HERE
