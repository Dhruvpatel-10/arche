#!/usr/bin/env bash
# ~/.blerc — ble.sh runtime config.
# ble.sh auto-sources this after `ble-attach`, so `ble-sabbrev` and friends
# are guaranteed to be loaded by the time we get here. Putting abbreviations
# in .bashrc before attach is too early — core-complete.sh isn't loaded yet.

# ── Inline history autosuggestion (fish-like) ──
# Default face renders as reverse-video on some palettes — force a dim-gray
# foreground with no background/reverse so suggestions blend into the prompt.
ble-face -s auto_complete fg=240

# Auto-complete from history only — never invoke programmable completion
# on every keystroke. Tab still triggers full bash-completion completion;
# this just keeps the inline ghost suggestion fish-like (history only).
bleopt complete_auto_complete_opts=syntax-disabled
_ble_complete_auto_source=(history)  # belt-and-suspenders override

# No auto-popup menu while typing. Tab still opens it on demand.
bleopt complete_auto_menu=

# Pasted multi-line text should run line-by-line, not enter MULTILINE edit mode.
# Disabling bracketed-paste makes ble.sh treat pasted newlines as Enter presses
# (each line executes immediately), same as plain bash. The downside: pasting
# a multi-line script you wanted to *edit before running* won't work — but you
# can still use a heredoc or paste into an editor for that case.
bleopt term_bracketed_paste_mode=

# Ctrl+Backspace → delete previous whitespace-delimited word.
# Kitty reports the key two ways depending on mode:
#   - Legacy: ^H (= C-h) — what `cat -v` sees
#   - Kitty keyboard protocol: C-DEL — what ble.sh sees once attached
# Bind both to kill-backward-uword (whitespace-only word, "delete back to
# previous space"). cword/eword split on shell metachars/punctuation and
# feel random.
ble-bind -f 'C-h'   kill-backward-uword
ble-bind -f 'C-DEL' kill-backward-uword

# General
ble-sabbrev c='clear'
ble-sabbrev ..='cd ..'
ble-sabbrev ...='cd ../..'
ble-sabbrev ....='cd ../../..'

# Git
ble-sabbrev g='git'
ble-sabbrev gcm='git commit -m'
ble-sabbrev gcam='git commit -a -m'
ble-sabbrev gcad='git commit -a --amend'
ble-sabbrev gst='git status -sb'
ble-sabbrev gd='git diff'
ble-sabbrev gds='git diff --staged'
ble-sabbrev glog='git log --oneline --graph --decorate -20'

# Tmux
ble-sabbrev tn='tmux new -s'
ble-sabbrev ta='tmux attach -t'
ble-sabbrev tls='tmux ls'
ble-sabbrev tk='tmux kill-session -t'
ble-sabbrev td='tmux detach'
ble-sabbrev t='tmux attach || tmux new'

# Network
ble-sabbrev myipv4='curl -s ipv4.icanhazip.com'
ble-sabbrev myipv6='curl -s ipv6.icanhazip.com'
