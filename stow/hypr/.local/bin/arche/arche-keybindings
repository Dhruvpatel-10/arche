#!/usr/bin/env bash
# hypr-keybindings — show all Hyprland keybindings in Walker dmenu
# Reads live bindings from hyprctl, resolves keycodes, displays in Walker.

set -euo pipefail

declare -A KEYCODE_SYM_MAP

build_keymap_cache() {
    local keymap
    keymap="$(xkbcli compile-keymap 2>/dev/null)" || return 0

    while IFS=, read -r code sym; do
        [[ -z $code || -z $sym ]] && continue
        KEYCODE_SYM_MAP["$code"]="$sym"
    done < <(
        awk '
            BEGIN { sec = "" }
            /xkb_keycodes/ { sec = "codes"; next }
            /xkb_symbols/  { sec = "syms";  next }
            sec == "codes" {
                if (match($0, /<([A-Za-z0-9_]+)>\s*=\s*([0-9]+)\s*;/, m)) code_by_name[m[1]] = m[2]
            }
            sec == "syms" {
                if (match($0, /key\s*<([A-Za-z0-9_]+)>\s*\{\s*\[\s*([^, \]]+)/, m)) sym_by_name[m[1]] = m[2]
            }
            END {
                for (k in code_by_name) {
                    c = code_by_name[k]
                    s = sym_by_name[k]
                    if (c != "" && s != "" && s != "NoSymbol") print c "," s
                }
            }
        ' <<<"$keymap"
    )
}

resolve_keycodes() {
    while IFS= read -r line; do
        if [[ $line =~ code:([0-9]+) ]]; then
            local code="${BASH_REMATCH[1]}"
            local symbol="${KEYCODE_SYM_MAP[$code]:-code:$code}"
            echo "${line/code:${code}/$symbol}"
        elif [[ $line =~ mouse:([0-9]+) ]]; then
            local code="${BASH_REMATCH[1]}"
            case "$code" in
                272) symbol="LMB" ;;
                273) symbol="RMB" ;;
                274) symbol="MMB" ;;
                *)   symbol="mouse:${code}" ;;
            esac
            echo "${line/mouse:${code}/$symbol}"
        else
            echo "$line"
        fi
    done
}

get_bindings() {
    hyprctl -j binds |
        jq -r '.[] | "\(.modmask),\(.key)@\(.keycode),\(.description),\(.dispatcher),\(.arg)"' |
        sed -r \
            -e 's/null//' \
            -e 's,uwsm-app -- ,,' \
            -e 's,uwsm app -- ,,' \
            -e 's/@0//' \
            -e 's/,@/,code:/' \
            -e 's/^0,/,/' \
            -e 's/^1,/SHIFT,/' \
            -e 's/^4,/CTRL,/' \
            -e 's/^5,/SHIFT CTRL,/' \
            -e 's/^8,/ALT,/' \
            -e 's/^9,/SHIFT ALT,/' \
            -e 's/^12,/CTRL ALT,/' \
            -e 's/^64,/SUPER,/' \
            -e 's/^65,/SUPER SHIFT,/' \
            -e 's/^68,/SUPER CTRL,/' \
            -e 's/^69,/SUPER SHIFT CTRL,/' \
            -e 's/^72,/SUPER ALT,/' \
            -e 's/^73,/SUPER SHIFT ALT,/' \
            -e 's/^76,/SUPER CTRL ALT,/' \
            -e 's/^77,/SUPER SHIFT CTRL ALT,/'
}

format_bindings() {
    awk -F, '
    {
        key_combo = $1 " + " $2
        gsub(/^[ \t]*\+?[ \t]*/, "", key_combo)
        gsub(/[ \t]+$/, "", key_combo)
        gsub(/[ \t]+/, " ", key_combo)

        action = $3
        if (action == "") {
            for (i = 4; i <= NF; i++)
                action = action $i (i < NF ? "," : "")
            sub(/,$/, "", action)
            gsub(/(^|,)[[:space:]]*exec[[:space:]]*,?/, "", action)
            gsub(/^[ \t]+|[ \t]+$/, "", action)
        }

        if (action != "") {
            keys[NR] = key_combo
            acts[NR] = action
        }
    }
    END {
        for (i = 1; i <= NR; i++)
            if (keys[i] != "")
                printf "%s\t%s\n", keys[i], acts[i]
    }'
}

main() {
    build_keymap_cache

    local output
    output="$(get_bindings | sort -u | resolve_keycodes | format_bindings | sort)"

    if [[ "${1:-}" == "--print" || "${1:-}" == "-p" ]]; then
        echo "$output"
    else
        local monitor_height
        monitor_height=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .height')
        local menu_height=$(( monitor_height * 40 / 100 ))

        echo "$output" | rofi -dmenu -p 'Keybindings' -i
    fi
}

main "$@"
