#!/usr/bin/env bash
# arche-powermenu ŌĆö rofi power menu for session/system actions
# Actions: Lock, Sleep, Logout, Reboot, Shutdown

set -euo pipefail

declare -A ACTIONS=(
    ["  Lock"]="loginctl lock-session"
    ["¾░Æ▓  Sleep"]="systemctl suspend"
    ["¾░łå  Logout"]="uwsm stop"
    ["¾░£ē  Reboot"]="systemctl reboot"
    ["¾░Éź  Shutdown"]="systemctl poweroff"
)

ORDERED=(
    "  Lock"
    "¾░Æ▓  Sleep"
    "¾░łå  Logout"
    "¾░£ē  Reboot"
    "¾░Éź  Shutdown"
)

choice=$(printf '%s\n' "${ORDERED[@]}" | rofi -dmenu -p 'Power' -i)

[[ -z "$choice" ]] && exit 0

cmd="${ACTIONS[$choice]:-}"
[[ -z "$cmd" ]] && exit 1

exec $cmd
