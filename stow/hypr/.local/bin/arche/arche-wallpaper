#!/usr/bin/env bash
# arche-wallpaper — browse and set wallpapers via swww
#
# Usage:
#   arche-wallpaper           — pick from wallpaper directory (fzf)
#   arche-wallpaper random    — set a random wallpaper
#   arche-wallpaper <path>    — set a specific image

set -euo pipefail

WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/Pictures/Wallpapers}"
TRANSITION="grow"
TRANSITION_DURATION=2
TRANSITION_FPS=60

# Ensure exactly one swww daemon is running
if ! swww query &>/dev/null; then
    swww-daemon &disown
    sleep 1
fi

set_wallpaper() {
    swww img "$1" \
        --transition-type "$TRANSITION" \
        --transition-duration "$TRANSITION_DURATION" \
        --transition-fps "$TRANSITION_FPS"
    notify-send -i "$1" "Wallpaper set" "$(basename "$1")"
}

# Ensure wallpaper directory exists
if [[ ! -d "$WALLPAPER_DIR" ]]; then
    notify-send "Wallpaper" "Create $WALLPAPER_DIR and add images"
    exit 1
fi

case "${1:-}" in
    random)
        pick=$(fd -e png -e jpg -e jpeg -e webp . "$WALLPAPER_DIR" | shuf -n1)
        [[ -n "$pick" ]] && set_wallpaper "$pick"
        ;;
    "")
        pick=$(fd -e png -e jpg -e jpeg -e webp . "$WALLPAPER_DIR" \
            | sort \
            | fzf --prompt="wallpaper > " \
                  --preview="kitty icat --clear --transfer-mode=memory --stdin=no --place=\${FZF_PREVIEW_COLUMNS}x\${FZF_PREVIEW_LINES}@0x0 {}" \
                  --preview-window=right:60%)
        [[ -n "$pick" ]] && set_wallpaper "$pick"
        ;;
    *)
        [[ -f "$1" ]] && set_wallpaper "$1" || { echo "File not found: $1"; exit 1; }
        ;;
esac
