# zathurarc — behavior config (stow-managed)
# Colors are in zathurarc-colors (rendered from template)

include zathurarc-colors

# ─── Clipboard ───

set selection-clipboard clipboard

# ─── Sandbox ───
# "strict" breaks Wayland clipboard and D-Bus — use "none" on Hyprland

set sandbox none

# ─── Zoom / Layout ───

set adjust-open "best-fit"
set zoom-step 10
set pages-per-row 1
set page-padding 1
set page-cache-size 15

# ─── Scroll ───

set scroll-page-aware true
set scroll-full-overlap 0.01
set scroll-step 40

# ─── Search ───

set incremental-search true
set search-hadjust true

# ─── Window ───

set window-title-basename true
set window-title-home-tilde true
set window-title-page true
set statusbar-home-tilde true

# ─── Recolor (dark mode) ───
# Toggle with Ctrl+r. Colors defined in template.

set recolor true
set recolor-keephue true
set recolor-reverse-video false

# ─── Database ───

set database sqlite

# ─── Keybinds ───
# Defaults are vim-style (j/k/gg/G/+/-/a/s/d/f/Tab/q)
# Only add custom bindings here

map D toggle_page_mode
map <C-l> reload
