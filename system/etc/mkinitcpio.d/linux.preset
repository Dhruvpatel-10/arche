# /etc/mkinitcpio.d/linux.preset — managed by arche (symlinked by link_system_all)
#
# UKI-only preset. The UKI bundles kernel + initramfs + cmdline + splash into
# one signed PE binary that systemd-boot auto-discovers from /boot/EFI/Linux/.
# See D024.

ALL_kver="/boot/vmlinuz-linux"
ALL_microcode=(/boot/*-ucode.img)

PRESETS=('default' 'fallback')

default_uki="/boot/EFI/Linux/arch-linux.efi"

fallback_uki="/boot/EFI/Linux/arch-linux-fallback.efi"
fallback_options="-S autodetect"
