#!/usr/bin/env bash
# usb-inspect — safely inspect unknown USB storage devices in a sandbox
#
# Workflow:
#   1. USBGuard blocks all unknown USB devices by default
#   2. This script lists blocked devices and lets you pick one
#   3. Temporarily allows it, waits for the block device to appear
#   4. Mounts it read-only (noexec, nosuid, nodev)
#   5. Opens a sandboxed shell via firejail (no network, caps dropped, seccomp)
#   6. On exit: unmounts, re-blocks the device
#   7. Asks whether to permanently allow the device
#
# Usage:
#   usb-inspect              — interactive: pick from blocked devices, inspect
#   usb-inspect list         — show all blocked USB devices
#   usb-inspect allow <ID>   — permanently allow a device by USBGuard ID
#
# Requires: usbguard, firejail, lsblk

set -euo pipefail

# ─── Logging (matches arche lib.sh style) ───

info()  { printf '\033[1;34m[INFO]\033[0m %s\n' "$*"; }
ok()    { printf '\033[1;32m[✓]\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m[~]\033[0m %s\n' "$*"; }
err()   { printf '\033[1;31m[✗]\033[0m %s\n' "$*" >&2; }
section() { printf '\n\033[1;36m── %s ──\033[0m\n\n' "$*"; }

# ─── Dependency check ───

for cmd in usbguard firejail lsblk; do
    if ! command -v "$cmd" &>/dev/null; then
        err "Required command not found: $cmd"
        exit 1
    fi
done

if ! systemctl is-active --quiet usbguard 2>/dev/null; then
    err "USBGuard is not running"
    info "Start it: sudo systemctl start usbguard"
    exit 1
fi

# ─── Cleanup trap ───
# Always unmount and re-block on exit, even on ctrl+c

MOUNT_POINT=""
ALLOWED_ID=""

cleanup() {
    if [[ -n "$MOUNT_POINT" ]] && mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
        warn "Unmounting $MOUNT_POINT..."
        sudo umount "$MOUNT_POINT" 2>/dev/null || sudo umount -l "$MOUNT_POINT" 2>/dev/null || true
    fi
    if [[ -n "$MOUNT_POINT" && -d "$MOUNT_POINT" ]]; then
        sudo rmdir "$MOUNT_POINT" 2>/dev/null || true
    fi
    if [[ -n "$ALLOWED_ID" ]]; then
        warn "Re-blocking USB device $ALLOWED_ID..."
        sudo usbguard block-device "$ALLOWED_ID" 2>/dev/null || true
        ok "Device $ALLOWED_ID blocked again"
    fi
}
trap cleanup EXIT

# ─── Helpers ───

list_blocked() {
    sudo usbguard list-devices 2>/dev/null | grep -i "block" || true
}

show_blocked() {
    local devices
    devices=$(list_blocked)

    if [[ -z "$devices" ]]; then
        info "No blocked USB devices found"
        info "All connected devices are either allowed or no new devices are plugged in"
        return 1
    fi

    echo "$devices" | while IFS= read -r line; do
        local id name
        id=$(echo "$line" | grep -oP '^\s*\K\d+')
        name=$(echo "$line" | grep -oP 'name "\K[^"]+' || echo "unknown")
        local serial
        serial=$(echo "$line" | grep -oP 'serial "\K[^"]+' || echo "n/a")
        printf "  [%s] %s (serial: %s)\n" "$id" "$name" "$serial"
    done
    return 0
}

wait_for_device() {
    local before="$1" max_wait=10 elapsed=0

    while [[ $elapsed -lt $max_wait ]]; do
        local after
        after=$(lsblk -dpno NAME 2>/dev/null | sort)
        local new_devs
        new_devs=$(comm -13 <(echo "$before") <(echo "$after") || true)

        if [[ -n "$new_devs" ]]; then
            echo "$new_devs" | head -1
            return 0
        fi

        sleep 1
        ((elapsed++))
    done

    return 1
}

pick_partition() {
    local device="$1"
    local parts
    parts=$(lsblk -lnpo NAME,SIZE,FSTYPE "$device" 2>/dev/null | tail -n +2 | grep -v "^$device " || true)

    # If no partitions, the device itself might be the filesystem
    if [[ -z "$parts" ]]; then
        local fstype
        fstype=$(lsblk -npo FSTYPE "$device" 2>/dev/null | head -1)
        if [[ -n "$fstype" ]]; then
            echo "$device"
            return 0
        fi
        return 1
    fi

    local count
    count=$(echo "$parts" | wc -l)

    if [[ "$count" -eq 1 ]]; then
        echo "$parts" | awk '{print $1}'
        return 0
    fi

    # Multiple partitions — let user pick
    info "Multiple partitions found:"
    local i=1
    echo "$parts" | while IFS= read -r line; do
        printf "  [%d] %s\n" "$i" "$line"
        ((i++))
    done

    printf "\nPick a partition [1-%d]: " "$count"
    local choice
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$count" ]]; then
        echo "$parts" | sed -n "${choice}p" | awk '{print $1}'
        return 0
    fi

    err "Invalid choice"
    return 1
}

# ─── Commands ───

cmd_list() {
    section "Blocked USB Devices"
    show_blocked
}

cmd_allow() {
    local id="${1:-}"
    if [[ -z "$id" ]]; then
        err "Usage: usb-inspect allow <device-id>"
        exit 1
    fi
    sudo usbguard allow-device -p "$id"
    ok "Device $id permanently allowed"
}

cmd_inspect() {
    section "USB Device Inspection"

    info "Scanning for blocked USB devices..."
    echo ""
    if ! show_blocked; then
        exit 0
    fi

    echo ""
    printf "Enter device ID to inspect (or 'q' to quit): "
    local device_id
    read -r device_id

    if [[ "$device_id" == "q" || -z "$device_id" ]]; then
        info "Cancelled"
        exit 0
    fi

    # Verify device exists in blocked list
    if ! list_blocked | grep -qP "^\s*$device_id:"; then
        err "Device $device_id not found in blocked list"
        exit 1
    fi

    # Record current block devices before allowing
    local before_devs
    before_devs=$(lsblk -dpno NAME 2>/dev/null | sort)

    section "Allowing Device Temporarily"
    info "Temporarily allowing device $device_id..."
    sudo usbguard allow-device "$device_id"
    ALLOWED_ID="$device_id"
    ok "Device allowed (will re-block on exit)"

    # Wait for block device to appear
    info "Waiting for block device to appear..."
    local new_device
    if ! new_device=$(wait_for_device "$before_devs"); then
        warn "No block device appeared — this may not be a storage device"
        info "Device is temporarily allowed. Press Enter to re-block and exit."
        read -r
        exit 0
    fi
    ok "Detected: $new_device"

    # Show device info
    echo ""
    info "Device details:"
    lsblk -o NAME,SIZE,FSTYPE,LABEL,MODEL "$new_device" 2>/dev/null || true
    echo ""

    # Pick partition
    local partition
    if ! partition=$(pick_partition "$new_device"); then
        err "No mountable filesystem found on $new_device"
        info "Press Enter to re-block and exit."
        read -r
        exit 0
    fi

    section "Mounting Read-Only"

    MOUNT_POINT=$(mktemp -d /mnt/usb-inspect.XXXXXX)
    info "Mount point: $MOUNT_POINT"
    info "Mounting $partition read-only (noexec, nosuid, nodev)..."

    if ! sudo mount -o ro,noexec,nosuid,nodev "$partition" "$MOUNT_POINT"; then
        err "Failed to mount $partition"
        sudo rmdir "$MOUNT_POINT" 2>/dev/null || true
        MOUNT_POINT=""
        info "Press Enter to re-block and exit."
        read -r
        exit 0
    fi
    ok "Mounted read-only at $MOUNT_POINT"

    # Show quick summary
    echo ""
    info "Quick scan:"
    local file_count dir_count
    file_count=$(find "$MOUNT_POINT" -type f 2>/dev/null | wc -l)
    dir_count=$(find "$MOUNT_POINT" -type d 2>/dev/null | wc -l)
    local total_size
    total_size=$(du -sh "$MOUNT_POINT" 2>/dev/null | awk '{print $1}')
    info "  Files: $file_count | Directories: $dir_count | Total size: $total_size"

    # Check for suspicious files
    local suspicious
    suspicious=$(find "$MOUNT_POINT" -type f \( \
        -name "*.exe" -o -name "*.bat" -o -name "*.cmd" -o -name "*.ps1" \
        -o -name "*.vbs" -o -name "*.scr" -o -name "*.pif" \
        -o -name "autorun.inf" -o -name "*.lnk" \
        -o -name ".DS_Store" \
    \) 2>/dev/null || true)

    if [[ -n "$suspicious" ]]; then
        echo ""
        warn "Suspicious files detected:"
        echo "$suspicious" | while IFS= read -r f; do
            warn "  $(basename "$f") — $(file -b "$f" 2>/dev/null || echo "unknown type")"
        done
    fi

    section "Sandboxed Shell"
    info "Entering firejail sandbox..."
    info "  - No network access"
    info "  - All capabilities dropped"
    info "  - Seccomp filtered"
    info "  - Isolated \$HOME (empty tmpfs)"
    info "  - USB mounted read-only at: $MOUNT_POINT"
    echo ""
    info "Useful commands: ls, file, strings, hexdump, stat, tree, du"
    info "Type 'exit' when done inspecting"
    echo ""

    # Launch sandboxed shell
    # --noprofile: no firejail profile, we define everything explicitly
    # --net=none: no network access (can't exfiltrate data)
    # --caps.drop=all: drop all Linux capabilities
    # --seccomp: enable seccomp filter (blocks dangerous syscalls)
    # --nonewprivs: prevent privilege escalation
    # --private: empty tmpfs $HOME (can't access user data)
    # --private-tmp: isolated /tmp
    # --private-dev: minimal /dev (no access to real devices)
    # --nosound --no3d: reduce attack surface
    firejail \
        --noprofile \
        --net=none \
        --nosound \
        --no3d \
        --noroot \
        --caps.drop=all \
        --seccomp \
        --nonewprivs \
        --private \
        --private-tmp \
        --private-dev \
        bash --norc --noprofile -c "
            export PS1='[usb-inspect \w]\$ '
            cd '$MOUNT_POINT' 2>/dev/null || cd /
            exec bash --norc --noprofile
        " || true

    section "Post-Inspection"

    info "Unmounting $MOUNT_POINT..."
    sudo umount "$MOUNT_POINT" 2>/dev/null || sudo umount -l "$MOUNT_POINT" 2>/dev/null || true
    sudo rmdir "$MOUNT_POINT" 2>/dev/null || true
    MOUNT_POINT=""

    echo ""
    printf "Permanently allow this device? [y/N]: "
    local allow_choice
    read -r allow_choice

    if [[ "$allow_choice" =~ ^[Yy]$ ]]; then
        sudo usbguard allow-device -p "$ALLOWED_ID"
        ALLOWED_ID=""
        ok "Device permanently allowed"
    else
        info "Device will be re-blocked on exit"
    fi
}

# ─── Main ───

case "${1:-}" in
    list)
        cmd_list
        ;;
    allow)
        cmd_allow "${2:-}"
        ;;
    -h|--help)
        echo "usb-inspect — safely inspect USB devices in a sandbox"
        echo ""
        echo "Usage:"
        echo "  usb-inspect          Interactive: pick a blocked device, inspect in sandbox"
        echo "  usb-inspect list     Show all blocked USB devices"
        echo "  usb-inspect allow ID Permanently allow a device by USBGuard ID"
        echo ""
        echo "Requires: usbguard (running), firejail, lsblk"
        ;;
    *)
        cmd_inspect
        ;;
esac
