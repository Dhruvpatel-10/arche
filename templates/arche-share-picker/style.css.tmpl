/* arche-share-picker — rendered by theme.sh */
/* Source: templates/arche-share-picker/style.css.tmpl */

@define-color bg         ${COLOR_BG};
@define-color bg_alt     ${COLOR_BG_ALT};
@define-color bg_surface ${COLOR_BG_SURFACE};
@define-color fg         ${COLOR_FG};
@define-color fg_muted   ${COLOR_FG_MUTED};
@define-color accent     ${COLOR_ACCENT};
@define-color border     ${COLOR_BORDER};
@define-color surface1   ${COLOR_SURFACE1};
@define-color surface2   ${COLOR_SURFACE2};
@define-color success    ${COLOR_SUCCESS};
@define-color warn       ${COLOR_WARN};
@define-color critical   ${COLOR_CRITICAL};

* {
    all: unset;
    font-family: '${FONT_SANS}', sans-serif;
    color: @fg;
    font-weight: 500;
    font-size: ${FONT_SIZE_NORMAL}pt;
}

/* ─── Outer layer-shell window ─── */

.picker-window {
    background: transparent;
}

/* ─── Root card ─── */

.picker-root {
    background: @bg;
    border: ${BORDER_SIZE}px solid alpha(@border, 0.55);
    border-radius: ${RADIUS}px;
    padding: 28px 32px 24px 32px;
    box-shadow: 0 24px 64px alpha(@bg_alt, 0.75),
                0 4px 16px alpha(@bg_alt, 0.5);
}

/* ─── Header ─── */

.picker-header {
    font-size: 16pt;
    font-weight: 700;
    color: @fg;
    letter-spacing: 0.2px;
    padding-bottom: 18px;
    border-bottom: ${BORDER_SIZE}px solid alpha(@border, 0.45);
    margin-bottom: 20px;
}

/* ─── Notebook (tab layout) ─── */

.picker-notebook {
    background: transparent;
    padding: 0;
}

.picker-notebook > header {
    background: transparent;
    border: none;
    padding: 0;
    margin-bottom: 16px;
}

.picker-notebook > header > tabs {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
}

.picker-notebook > header > tabs > tab {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 18px;
    margin: 0 2px;
    transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
}

.picker-notebook > header > tabs > tab:hover {
    background: alpha(@accent, 0.08);
    border-bottom-color: alpha(@accent, 0.4);
}

.picker-notebook > header > tabs > tab:checked {
    background: alpha(@accent, 0.12);
    border-bottom-color: @accent;
}

.picker-tab-label {
    font-size: 10pt;
    font-weight: 700;
    color: @fg_muted;
    letter-spacing: 1.2px;
}

.picker-notebook > header > tabs > tab:hover .picker-tab-label {
    color: @fg;
}

.picker-notebook > header > tabs > tab:checked .picker-tab-label {
    color: @accent;
}

.picker-notebook > stack {
    background: transparent;
    padding: 0;
}

/* ─── Page container + scroll ─── */

.picker-page {
    background: transparent;
}

.picker-scroll {
    background: transparent;
}

.picker-scroll scrollbar {
    background: transparent;
    border: none;
    min-width: 8px;
    margin-left: 4px;
}

.picker-scroll scrollbar slider {
    background: alpha(@fg_muted, 0.35);
    border-radius: 4px;
    min-width: 6px;
    min-height: 32px;
}

.picker-scroll scrollbar slider:hover {
    background: alpha(@fg_muted, 0.65);
}

/* ─── Monitor grid (FlowBox) ─── */

.monitor-grid {
    background: transparent;
    padding: 0;
}

.monitor-grid > flowboxchild {
    background: transparent;
    padding: 0;
    border-radius: ${RADIUS}px;
}

.monitor-tile {
    background: @bg_surface;
    /* Resting: nearly-invisible border so unselected tiles read as "calm". */
    border: 1px solid alpha(@border, 0.5);
    border-radius: ${RADIUS}px;
    min-height: 116px;
    min-width: 180px;
    transition: background 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
}

.monitor-tile:hover {
    background: @surface1;
    border-color: alpha(@accent, 0.5);
}

/* Picker selection (keyboard / click) — the bold, unambiguous state. */
.monitor-tile:selected {
    background: alpha(@accent, 0.16);
    border: 2px solid @accent;
}

/* Hyprland-focused monitor — very subtle hint, never confused for selected.
   Small accent corner glow + slightly brighter surface; NO amber border. */
.monitor-tile.focused {
    background: @surface1;
    box-shadow: inset 3px 0 0 alpha(@accent, 0.6);
}

.monitor-tile-body {
    background: transparent;
    padding: 14px 16px;
}

.monitor-tile-icon {
    -gtk-icon-size: 22px;
    color: @accent;
    padding-bottom: 10px;
    opacity: 0.9;
}

.monitor-name {
    font-size: 12pt;
    font-weight: 700;
    color: @fg;
    padding-bottom: 2px;
}

.monitor-description {
    font-size: 9pt;
    color: @fg_muted;
    padding-bottom: 4px;
}

.monitor-subtitle {
    font-size: 10pt;
    color: @fg_muted;
}

/* ─── Window list ─── */

.window-list {
    background: transparent;
    border: none;
}

.window-row {
    background: @bg_surface;
    border: ${BORDER_SIZE}px solid alpha(@border, 0.28);
    border-radius: ${RADIUS}px;
    padding: 10px 14px;
    margin: 3px 0;
    transition: background 120ms ease, border-color 120ms ease;
}

.window-row:hover {
    background: @surface1;
    border-color: alpha(@accent, 0.5);
}

.window-row:selected {
    background: alpha(@accent, 0.14);
    border-color: @accent;
    border-left-width: 3px;
}

.window-row-body,
.window-row-text {
    background: transparent;
}

.window-icon {
    -gtk-icon-size: 28px;
    min-width: 28px;
    min-height: 28px;
    margin-right: 14px;
    color: @fg;
}

.window-title {
    font-size: 12pt;
    font-weight: 600;
    color: @fg;
    padding-bottom: 2px;
}

.window-subtitle {
    font-size: 10pt;
    font-weight: 500;
    color: @fg_muted;
}

/* ─── Region button ─── */

.region-button {
    background: alpha(@accent, 0.1);
    border: ${BORDER_SIZE}px solid alpha(@accent, 0.5);
    border-radius: ${RADIUS}px;
    padding: 14px 20px;
    margin-top: 4px;
    transition: background 120ms ease, border-color 120ms ease;
}

.region-button:hover {
    background: alpha(@accent, 0.2);
    border-color: @accent;
}

.region-button:active {
    background: alpha(@accent, 0.32);
}

.region-button-body {
    background: transparent;
}

.region-button-icon {
    -gtk-icon-size: 20px;
    min-width: 20px;
    min-height: 20px;
    color: @accent;
    margin-right: 12px;
}

.region-button-label {
    font-size: 12pt;
    font-weight: 700;
    color: @accent;
    letter-spacing: 0.2px;
}

/* ─── Empty state ─── */

.picker-empty {
    padding: 40px 20px;
    background: transparent;
}

.picker-empty-title {
    font-size: 14pt;
    font-weight: 700;
    color: @fg;
    padding-bottom: 8px;
}

.picker-empty-hint {
    font-size: 11pt;
    color: @fg_muted;
    padding-bottom: 18px;
}

.picker-empty-close {
    background: @bg_surface;
    border: ${BORDER_SIZE}px solid alpha(@border, 0.5);
    border-radius: ${RADIUS}px;
    padding: 8px 20px;
    font-size: 11pt;
    color: @fg;
    transition: background 120ms ease, border-color 120ms ease;
}

.picker-empty-close:hover {
    background: @surface1;
    border-color: alpha(@accent, 0.6);
    color: @fg;
}

/* ─── Footer ─── */

.picker-footer {
    border-top: ${BORDER_SIZE}px solid alpha(@border, 0.35);
    padding-top: 14px;
    margin-top: 18px;
    font-size: 10pt;
    color: @fg_muted;
    letter-spacing: 0.4px;
}
