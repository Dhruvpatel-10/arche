{
    "document": {
        "block_prefix": "\n",
        "block_suffix": "\n",
        "margin": 2
    },
    "heading": {
        "bold": true,
        "color": "${COLOR_ACCENT_NOHASH}",
        "block_suffix": "\n",
        "prefix": ""
    },
    "h1": {
        "bold": true,
        "color": "${COLOR_ACCENT_NOHASH}",
        "prefix": "",
        "suffix": "",
        "upper": true,
        "block_suffix": "\n"
    },
    "h2": {
        "bold": true,
        "color": "${COLOR_ACCENT_NOHASH}",
        "prefix": "",
        "block_suffix": "\n"
    },
    "h3": {
        "bold": true,
        "color": "${COLOR_ACCENT_ALT_NOHASH}",
        "prefix": "",
        "block_suffix": "\n"
    },
    "h4": {
        "bold": true,
        "color": "${COLOR_ACCENT_ALT_NOHASH}",
        "prefix": "",
        "block_suffix": "\n"
    },
    "h5": {
        "bold": true,
        "color": "${COLOR_FG_MUTED_NOHASH}",
        "prefix": "",
        "block_suffix": "\n"
    },
    "h6": {
        "bold": true,
        "color": "${COLOR_FG_MUTED_NOHASH}",
        "prefix": "",
        "block_suffix": "\n"
    },
    "paragraph": {},
    "text": {},
    "strong": {
        "bold": true,
        "color": "${COLOR_FG_NOHASH}"
    },
    "emph": {
        "italic": true,
        "color": "${COLOR_ACCENT_ALT_NOHASH}"
    },
    "strikethrough": {
        "strikethrough": true
    },
    "link": {
        "color": "${COLOR_ACCENT_ALT_NOHASH}",
        "underline": true
    },
    "link_text": {
        "color": "${COLOR_ACCENT_NOHASH}",
        "bold": true
    },
    "list": {
        "level_indent": 2
    },
    "item": {
        "block_prefix": "  "
    },
    "enumeration": {
        "block_prefix": "  "
    },
    "code_block": {
        "color": "${COLOR_FG_NOHASH}",
        "background_color": "${COLOR_BG_SURFACE_NOHASH}",
        "margin": 2,
        "chroma": {
            "theme": "monokai"
        }
    },
    "code": {
        "color": "${COLOR_ACCENT_NOHASH}",
        "background_color": "${COLOR_BG_SURFACE_NOHASH}"
    },
    "block_quote": {
        "indent": 1,
        "indent_token": "│ ",
        "color": "${COLOR_FG_MUTED_NOHASH}"
    },
    "table": {
        "center_separator": "┼",
        "column_separator": "│",
        "row_separator": "─",
        "color": "${COLOR_FG_NOHASH}"
    },
    "horizontal_rule": {
        "color": "${COLOR_BORDER_NOHASH}",
        "format": "─"
    },
    "definition_term": {
        "bold": true,
        "color": "${COLOR_ACCENT_NOHASH}"
    },
    "definition_description": {
        "block_prefix": "  "
    },
    "image": {
        "color": "${COLOR_ACCENT_ALT_NOHASH}",
        "underline": true
    },
    "image_text": {
        "color": "${COLOR_FG_MUTED_NOHASH}",
        "format": "Image: {{.text}}"
    }
}
