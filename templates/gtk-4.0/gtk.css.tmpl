/* Ember accent overrides for Adwaita-dark (GTK4 / libadwaita) */

@define-color accent_bg_color ${COLOR_ACCENT};
@define-color accent_fg_color ${COLOR_BG};
@define-color accent_color ${COLOR_ACCENT};
@define-color window_bg_color ${COLOR_BG};
@define-color window_fg_color ${COLOR_FG};
@define-color view_bg_color ${COLOR_BG_ALT};
@define-color view_fg_color ${COLOR_FG};
@define-color headerbar_bg_color ${COLOR_BG_SURFACE};
@define-color headerbar_fg_color ${COLOR_FG};
@define-color card_bg_color ${COLOR_BG_SURFACE};
@define-color card_fg_color ${COLOR_FG};
@define-color popover_bg_color ${COLOR_BG_SURFACE};
@define-color popover_fg_color ${COLOR_FG};
@define-color sidebar_bg_color ${COLOR_BG_ALT};
@define-color sidebar_fg_color ${COLOR_FG};
/* libadwaita backdrop variants drop the _bg suffix — see src/stylesheet/widgets/_sidebars.scss */
@define-color sidebar_backdrop_color ${COLOR_BG_ALT};
@define-color sidebar_shade_color ${COLOR_BG};
@define-color sidebar_border_color ${COLOR_BG};
@define-color secondary_sidebar_bg_color ${COLOR_BG_ALT};
@define-color secondary_sidebar_fg_color ${COLOR_FG};
@define-color secondary_sidebar_backdrop_color ${COLOR_BG_ALT};
@define-color secondary_sidebar_shade_color ${COLOR_BG};
@define-color secondary_sidebar_border_color ${COLOR_BG};
@define-color headerbar_backdrop_color ${COLOR_BG_SURFACE};

/* Belt-and-suspenders: pin the CSS custom properties libadwaita actually reads */
window, .background {
    --sidebar-backdrop-color: ${COLOR_BG_ALT};
    --secondary-sidebar-backdrop-color: ${COLOR_BG_ALT};
}
.sidebar-pane:backdrop,
.sidebar-pane:backdrop .navigation-sidebar {
    background-color: ${COLOR_BG_ALT};
}
@define-color dialog_bg_color ${COLOR_BG_SURFACE};
@define-color dialog_fg_color ${COLOR_FG};
@define-color destructive_bg_color ${COLOR_CRITICAL};
@define-color destructive_fg_color ${COLOR_FG};
@define-color success_bg_color ${COLOR_SUCCESS};
@define-color success_fg_color ${COLOR_BG};
@define-color warning_bg_color ${COLOR_WARN};
@define-color warning_fg_color ${COLOR_BG};
@define-color error_bg_color ${COLOR_CRITICAL};
@define-color error_fg_color ${COLOR_FG};
