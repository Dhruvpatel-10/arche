/* Ember — rofi launcher theme. Generated by theme.sh, do not edit. */

* {
    /* ─── Palette ─── */
    bg-modal:      #0b0d14ea;
    bg-wash:       #c9943e1c;
    border-soft:   #cdc8bc1a;
    fg:            ${COLOR_FG};
    fg-muted:      ${COLOR_FG_MUTED};
    fg-dim:        #cdc8bc55;
    accent:        ${COLOR_ACCENT};
    accent-alt:    ${COLOR_ACCENT_ALT};
    critical:      ${COLOR_CRITICAL};
    none:          transparent;

    /* ─── Typography ─── */
    font:                "${FONT_SANS} 13";
    text-color:          @fg;
    background-color:    @none;
}

/* ━━━ Window ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 * Fullscreen + transparent so the layer-shell surface receives clicks
 * everywhere — prerequisite for `click-to-exit` to fire outside the modal.
 */

window {
    fullscreen:          true;
    transparency:        "real";
    background-color:    transparent;
    padding:             0;
    border:              0;
    border-radius:       0;
    children:            [ outerbox ];
}

outerbox {
    orientation:         vertical;
    background-color:    transparent;
    spacing:             0;
    children:            [ vspacer-top, midrow, vspacer-bot ];
}

midrow {
    orientation:         horizontal;
    background-color:    transparent;
    spacing:             0;
    children:            [ hspacer-l, modal, hspacer-r ];
}

vspacer-top, vspacer-bot, hspacer-l, hspacer-r {
    background-color:    transparent;
    expand:              true;
}

modal {
    expand:              false;
    background-color:    @bg-modal;
    border:              1px;
    border-color:        @border-soft;
    border-radius:       14px;
    children:            [ mainbox ];
}

/* ━━━ Layout ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

mainbox {
    width:               640px;
    spacing:             0;
    background-color:    transparent;
    children:            [ inputbar, listview, mode-switcher ];
}

/* ━━━ Search bar ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 * The native `prompt` widget surfaces rofi's mode label (Apps/Run/Files/…)
 * or the -dmenu -p flag (Clipboard/Delete/Emoji…). One widget, two purposes,
 * zero bolted-on chrome.
 */

inputbar {
    padding:             20px 26px 18px 26px;
    spacing:             14px;
    children:            [ prompt, entry ];
}

prompt {
    enabled:             true;
    expand:              false;
    text-color:          @accent;
    font:                "${FONT_SANS} Medium 10";
    vertical-align:      0.55;
    padding:             0 4px 0 0;
}

entry {
    font:                "${FONT_SANS} 15";
    text-color:          @fg;
    placeholder:         "Search";
    placeholder-color:   @fg-dim;
    cursor-color:        @accent;
    cursor-width:        1px;
    vertical-align:      0.5;
}

/* ━━━ Results ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

listview {
    lines:               7;
    columns:             1;
    fixed-height:        false;
    scrollbar:           false;
    padding:             4px 12px 12px 12px;
    spacing:             1px;
    border:              0;
}

element {
    padding:             10px 14px;
    spacing:             14px;
    border-radius:       8px;
    cursor:              pointer;
}

element normal.normal,
element alternate.normal {
    text-color:          @fg;
}

element normal.active,
element alternate.active {
    text-color:          @accent-alt;
}

element normal.urgent,
element alternate.urgent {
    text-color:          @critical;
}

element selected.normal,
element selected.active {
    background-color:    @bg-wash;
    text-color:          @fg;
    border:              0;
}

element selected.urgent {
    background-color:    @bg-wash;
    text-color:          @critical;
    border:              0;
}

element-icon {
    size:                22px;
    vertical-align:      0.5;
    cursor:              inherit;
}

element-text {
    vertical-align:      0.5;
    cursor:              inherit;
    highlight:           bold ${COLOR_ACCENT};
}

/* ━━━ Mode switcher ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 * Single-effect active state: color shift only. No background, no underline,
 * no weight stacking. The typographic rhythm carries the hierarchy.
 */

mode-switcher {
    padding:             12px 22px;
    spacing:             22px;
    border:              1px 0 0 0;
    border-color:        @border-soft;
}

button {
    padding:             2px 2px;
    horizontal-align:    0.5;
    text-color:          @fg-dim;
    font:                "${FONT_SANS} 10";
    cursor:              pointer;
    background-color:    transparent;
    border:              0;
}

button selected {
    text-color:          @accent;
    font:                "${FONT_SANS} Medium 10";
    background-color:    transparent;
    border:              0;
}

/* ━━━ Messages ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

message {
    padding:             10px 24px;
    border:              1px 0 0 0;
    border-color:        @border-soft;
}

textbox {
    text-color:          @fg-muted;
}

/* ━━━ Scrollbar ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

scrollbar {
    handle-width:        2px;
    handle-color:        @fg-dim;
    border-radius:       2px;
    margin:              4px 0;
}
