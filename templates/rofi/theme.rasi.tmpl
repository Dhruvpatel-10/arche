/* Ember — rofi launcher theme. Generated by theme.sh, do not edit. */

* {
    /* ─── Palette ─── */
    bg:             #13151ccc;
    bg-solid:       ${COLOR_BG};
    bg-alt:         ${COLOR_BG_ALT};
    bg-surface:     ${COLOR_BG_SURFACE};
    bg-hover:       #1d202966;
    fg:             ${COLOR_FG};
    fg-muted:       ${COLOR_FG_MUTED};
    fg-dim:         ${COLOR_OVERLAY0};
    accent:         ${COLOR_ACCENT};
    accent-alt:     ${COLOR_ACCENT_ALT};
    border-col:     ${COLOR_SURFACE1};
    critical:       ${COLOR_CRITICAL};
    none:           transparent;

    /* ─── Typography ─── */
    font:                "${FONT_SANS} 13";
    text-color:          @fg;
    background-color:    @none;
}

/* ━━━ Window ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

window {
    width:               680px;
    location:            center;
    anchor:              center;
    transparency:        "real";
    background-color:    @bg;
    border:              1px;
    border-color:        @border-col;
    border-radius:       16px;
}

/* ━━━ Layout ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

mainbox {
    children:            [ inputbar, listview, mode-switcher ];
    spacing:             0;
}

/* ━━━ Search bar ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

inputbar {
    padding:             16px 24px;
    spacing:             12px;
    children:            [ textbox-icon, entry ];
}

/* Search icon (magnifying glass via Unicode) */
textbox-icon {
    str:                 "";
    expand:              false;
    text-color:          @accent;
    font:                "${FONT_MONO} 16";
    vertical-align:      0.5;
}

entry {
    font:                "${FONT_SANS} 14";
    text-color:          @fg;
    placeholder:         "Search apps, files, commands...";
    placeholder-color:   @fg-dim;
    cursor-color:        @accent;
    cursor-width:        2px;
    vertical-align:      0.5;
}

/* ━━━ Results ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

listview {
    lines:               8;
    columns:             1;
    fixed-height:        false;
    scrollbar:           false;
    padding:             4px 8px;
    spacing:             2px;
    border:              1px 0 0 0;
    border-color:        @border-col;
}

element {
    padding:             10px 16px;
    spacing:             14px;
    border-radius:       10px;
    cursor:              pointer;
}

element normal.normal,
element alternate.normal {
    text-color:          @fg;
}

element normal.active,
element alternate.active {
    text-color:          @accent-alt;
}

element normal.urgent,
element alternate.urgent {
    text-color:          @critical;
}

element selected.normal {
    background-color:    @bg-hover;
    text-color:          @accent;
    border:              0 0 0 3px;
    border-color:        @accent;
}

element selected.active {
    background-color:    @bg-hover;
    text-color:          @accent;
    border:              0 0 0 3px;
    border-color:        @accent;
}

element selected.urgent {
    background-color:    @bg-hover;
    text-color:          @critical;
    border:              0 0 0 3px;
    border-color:        @critical;
}

element-icon {
    size:                24px;
    vertical-align:      0.5;
    cursor:              inherit;
}

element-text {
    vertical-align:      0.5;
    cursor:              inherit;
    highlight:           bold ${COLOR_ACCENT};
}

/* ━━━ Mode switcher ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

mode-switcher {
    padding:             8px 16px;
    spacing:             4px;
    border:              1px 0 0 0;
    border-color:        @border-col;
}

button {
    padding:             6px 16px;
    border-radius:       8px;
    text-color:          @fg-dim;
    font:                "${FONT_SANS} 10";
    cursor:              pointer;
}

button selected {
    background-color:    @bg-hover;
    text-color:          @accent;
    font:                "${FONT_SANS} Bold 10";
    border:              0 0 2px 0;
    border-color:        @accent;
}

/* ━━━ Messages ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

message {
    padding:             12px 24px;
    border:              1px 0 0 0;
    border-color:        @border-col;
}

textbox {
    text-color:          @fg-muted;
}

/* ━━━ Scrollbar ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

scrollbar {
    handle-width:        3px;
    handle-color:        @border-col;
    border-radius:       3px;
    margin:              4px 0;
}
