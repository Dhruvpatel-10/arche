/* Syshud OSD — rendered by theme.sh, do not edit manually. */
/* Source: templates/sys64/hud/style.css.tmpl */

/* ─── Reset ─── */

#syshud,
#syshud * {
    all: unset;
}

#syshud {
    background: transparent;
}

/* ─── Container ─── */
/* Semi-transparent with compositor blur behind. */

#syshud .box_layout {
    background: alpha(${COLOR_BG}, 0.62);
    border-radius: 16px;
    border: none;
    padding: 14px 24px;
    margin: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    transition: opacity 150ms ease-out;
}

/* ─── Icon ─── */

#syshud image {
    color: ${COLOR_FG};
    -gtk-icon-size: 18px;
    margin-right: 16px;
    opacity: 0.8;
    transition: color 200ms ease-out, opacity 200ms ease-out;
}

/* ─── Label ─── */

#syshud label {
    font-family: '${FONT_SANS}', sans-serif;
    font-size: 10pt;
    font-weight: 500;
    color: ${COLOR_FG};
    opacity: 0.7;
    min-width: 34px;
    margin-left: 16px;
    transition: color 200ms ease-out;
}

/* ─── Scale ─── */

#syshud scale {
    padding: 0;
    margin: 0;
    min-height: 6px;
    min-width: 6px;
}

/* ─── Trough ─── */

#syshud scale trough {
    border-radius: 999px;
    background: alpha(${COLOR_FG}, 0.1);
    min-height: 6px;
    min-width: 6px;
    padding: 0;
    border: none;
}

/* ─── Filled Bar ─── */

#syshud scale highlight,
#syshud scale.horizontal highlight {
    border-radius: 999px;
    min-height: 6px;
    min-width: 6px;
    margin: 0;
    padding: 0;
    border: none;
    background: ${COLOR_FG};
    opacity: 0.85;
    transition: all 120ms ease-out;
}

/* ─── Thumb ─── */

#syshud scale slider {
    min-height: 0;
    min-width: 0;
    margin: -1px;
    padding: 0;
    border: none;
    background: transparent;
    box-shadow: none;
    opacity: 0;
}

/* ─── States ─── */

#syshud .muted image {
    color: ${COLOR_CRITICAL};
    opacity: 0.6;
}
#syshud .muted scale highlight,
#syshud .muted scale.horizontal highlight {
    background: ${COLOR_CRITICAL};
    opacity: 0.5;
}
#syshud .muted label {
    color: ${COLOR_CRITICAL};
    opacity: 0.5;
}

#syshud .high image {
    color: ${COLOR_WARN};
}
#syshud .high scale highlight,
#syshud .high scale.horizontal highlight {
    background: ${COLOR_WARN};
}
