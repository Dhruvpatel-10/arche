# ─── Pane borders ───
set -g pane-border-style "fg=${COLOR_BORDER}"
set -g pane-active-border-style "fg=${COLOR_ACCENT}"

# ─── Status bar ───
set -g status-style "bg=default,fg=default"
set -g status-left "#[fg=${COLOR_BG_ALT},bg=${COLOR_ACCENT},bold] #S #[bg=default] "
set -g status-right "#[fg=${COLOR_ACCENT}]#{?client_prefix,PREFIX ,}#[fg=${COLOR_FG_MUTED}]#h "

# ─── Window tabs ───
set -g window-status-format "#[fg=${COLOR_FG_MUTED}] #I:#W "
set -g window-status-current-format "#[fg=${COLOR_ACCENT},bold] #I:#W "

# ─── Messages & command line ───
set -g message-style "bg=default,fg=${COLOR_ACCENT}"
set -g message-command-style "bg=default,fg=${COLOR_ACCENT}"

# ─── Copy mode highlight ───
setw -g mode-style "bg=${COLOR_ACCENT},fg=${COLOR_BG_ALT}"
setw -g clock-mode-colour "${COLOR_ACCENT}"
