# Arche btop theme — rendered by theme.sh, do not edit manually.
# Source: templates/btop/arche.theme.tmpl

# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]="${COLOR_BG}"

# Main text color
theme[main_fg]="${COLOR_FG}"

# Title color for boxes
theme[title]="${COLOR_FG}"

# Highlight color for keyboard shortcuts
theme[hi_fg]="${COLOR_ACCENT}"

# Background color of selected item in processes box
theme[selected_bg]="${COLOR_BG_SURFACE}"

# Foreground color of selected item in processes box
theme[selected_fg]="${COLOR_ACCENT}"

# Color of inactive/disabled text
theme[inactive_fg]="${COLOR_FG_MUTED}"

# Color of text appearing on top of graphs, i.e uptime and current network graph scaling
theme[graph_text]="${COLOR_FG_MUTED}"

# Background color of the percentage meters
theme[meter_bg]="${COLOR_BG_SURFACE}"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="${COLOR_FG_MUTED}"

# CPU, Memory, Network, Proc box outline colors
theme[cpu_box]="${COLOR_ACCENT}"
theme[mem_box]="${COLOR_SUCCESS}"
theme[net_box]="${COLOR_SKY}"
theme[proc_box]="${COLOR_ACCENT_ALT}"

# Box divider line and small boxes line color
theme[div_line]="${COLOR_BORDER}"

# Temperature graph color (Green -> Yellow -> Red)
theme[temp_start]="${COLOR_SUCCESS}"
theme[temp_mid]="${COLOR_WARN}"
theme[temp_end]="${COLOR_CRITICAL}"

# CPU graph colors
theme[cpu_start]="${COLOR_TEAL}"
theme[cpu_mid]="${COLOR_ACCENT_ALT}"
theme[cpu_end]="${COLOR_ACCENT}"

# Mem/Disk free meter
theme[free_start]="${COLOR_MAUVE}"
theme[free_mid]="${COLOR_ACCENT_ALT}"
theme[free_end]="${COLOR_SKY}"

# Mem/Disk cached meter
theme[cached_start]="${COLOR_SKY}"
theme[cached_mid]="${COLOR_ACCENT_ALT}"
theme[cached_end]="${COLOR_TEAL}"

# Mem/Disk available meter
theme[available_start]="${COLOR_PEACH}"
theme[available_mid]="${COLOR_WARN}"
theme[available_end]="${COLOR_CRITICAL}"

# Mem/Disk used meter
theme[used_start]="${COLOR_SUCCESS}"
theme[used_mid]="${COLOR_TEAL}"
theme[used_end]="${COLOR_SKY}"

# Download graph colors
theme[download_start]="${COLOR_PEACH}"
theme[download_mid]="${COLOR_WARN}"
theme[download_end]="${COLOR_CRITICAL}"

# Upload graph colors
theme[upload_start]="${COLOR_SUCCESS}"
theme[upload_mid]="${COLOR_TEAL}"
theme[upload_end]="${COLOR_SKY}"

# Process box color gradient for threads, mem and cpu usage
theme[process_start]="${COLOR_SKY}"
theme[process_mid]="${COLOR_ACCENT_ALT}"
theme[process_end]="${COLOR_MAUVE}"
