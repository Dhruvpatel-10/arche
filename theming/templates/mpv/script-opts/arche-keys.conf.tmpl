# Colors for scripts/arche-keys.lua (the curated keyboard cheatsheet),
# rendered by the theme engine into ~/.config/mpv/script-opts/arche-keys.conf.
#
# NOTE: these are raw ASS hex in BBGGRR order (byte-swapped, no #), because the
# script feeds them straight into ASS \c tags — hence the _BGR variant, not the
# #RRGGBB the foreign-app templates use.
key_color=${COLOR_ACCENT_BGR}
text_color=${COLOR_FG_BGR}
bg_color=${COLOR_BG_BGR}
border_color=${COLOR_ACCENT_BGR}
muted_color=${COLOR_FG_MUTED_BGR}
bg_opacity=0.94
scale=1.0
