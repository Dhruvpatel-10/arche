# arche-osc colours, rendered by the theme engine from the active theme into
# ~/.config/mpv/script-opts/arche-osc.conf. Read by scripts/arche-osc.lua.
#
# Only theme-driven values live here. Sizing and behaviour defaults are in the
# script; uncomment and set any of them here to override (scale, hide_delay,
# panel_opacity, jump_seconds, show_while_paused).

accent=${COLOR_ACCENT_NOHASH}
fg=${COLOR_FG_NOHASH}
bg=${COLOR_BG_NOHASH}
track=${COLOR_OVERLAY1_NOHASH}
panel_opacity=0.72
scale=1.0
hide_delay=1.5
