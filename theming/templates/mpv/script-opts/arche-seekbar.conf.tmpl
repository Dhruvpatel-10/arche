# Colors for scripts/arche-seekbar.lua (the sleek seek indicator), rendered by
# the theme engine into ~/.config/mpv/script-opts/arche-seekbar.conf.
#
# NOTE: raw ASS hex in BBGGRR order (byte-swapped, no #) — the script feeds
# these straight into ASS \c tags, hence the _BGR variant.
track_color=${COLOR_FG_MUTED_BGR}
fill_color=${COLOR_ACCENT_BGR}
knob_color=${COLOR_ACCENT_BGR}
text_color=${COLOR_FG_BGR}
track_alpha=0.28
