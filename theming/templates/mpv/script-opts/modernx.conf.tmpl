# modernX OSC — arche premium tuning.
# Rendered by theming/engine.sh from
#   theming/templates/mpv/script-opts/modernx.conf.tmpl
# Colors follow the active theme; sizing and behaviour are tuned for a larger,
# smoother, macOS-grade controller. Network and SponsorBlock features are off.
# modernX loads this via read_options(user_opts, 'modernx').

# ── Scale and button sizing (larger, for Retina and fullscreen) ──
vid_scale=no
scale_windowed=1.1
scale_fullscreen=1.3
scale_forced_window=1.1
playpause_size=36
midbuttons_size=28
sidebuttons_size=26

# ── Behaviour (smooth fade, stays visible while paused) ──
hide_timeout=1000
fade_duration=200
seek_resets_hide_timeout=yes
bottom_hover=yes
bottom_hover_zone=240
show_on_pause=yes
keep_on_pause=yes
min_mouse_move=0

# ── Title bar (borderless and fullscreen) ──
window_top_bar=auto
window_title=yes
window_controls=yes

# ── Title, time and description ──
show_title=yes
dynamic_title=yes
title=${media-title}
title_font_size=30
time_total=yes
time_format=dynamic
time_font_size=20
show_description=yes
show_file_size=yes
description_font_size=18
show_chapter_title=yes
show_chapter_markers=yes

# ── Seekbar and progress (thicker bar, visible handle, rounded thumbnails) ──
seekbar_height=5
progress_bar_height=18
seek_handle_size=1.0
seek_range=yes
seek_range_alpha=160
thumbnail_border=2
thumbnail_border_radius=4

# ── Buttons (useful set, no network or download) ──
compact_mode=yes
jump_buttons=yes
jump_amount=10
chapter_skip_buttons=yes
track_nextprev_buttons=yes
volume_control=yes
ontop_button=yes
screenshot_button=yes
info_button=no
loop_button=no
download_button=no

# ── Hover feel (subtle grow plus accent glow) ──
hover_effect=size,glow,color
hover_button_size=110
button_glow_amount=6

# ── Fade and blur (soft backdrop behind the bar) ──
fade_alpha=100
fade_blur_strength=80
window_fade_alpha=100
window_fade_blur_strength=80

# ── Subtitles rise above the OSC while it is shown ──
raise_subtitles=yes
raise_subtitle_amount=160

# ── Privacy: no phone-home. SponsorBlock and YouTube fetching disabled. ──
show_sponsorblock_segments=no
add_sponsorblock_chapters=no
title_youtube_stats=no
show_youtube_comments=no

# ── Colors (from the active theme) ──
osc_color=${COLOR_BG}
title_color=${COLOR_FG}
time_color=${COLOR_FG}
chapter_title_color=${COLOR_SUBTEXT1}
seekbarfg_color=${COLOR_ACCENT}
seekbarbg_color=${COLOR_SUBTEXT1}
seekbar_cache_color=${COLOR_SURFACE2}
side_buttons_color=${COLOR_FG}
middle_buttons_color=${COLOR_FG}
playpause_color=${COLOR_FG}
held_element_color=${COLOR_ACCENT}
hover_effect_color=${COLOR_ACCENT}
thumbnail_border_color=${COLOR_ACCENT}
window_title_color=${COLOR_FG}
window_controls_color=${COLOR_SUBTEXT1}
window_controls_close_hover=${COLOR_CRITICAL}
window_controls_minmax_hover=${COLOR_ACCENT}
