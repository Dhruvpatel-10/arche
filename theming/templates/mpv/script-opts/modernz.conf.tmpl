# ModernZ, skinned with the arche theme. Rendered by the theme engine into
# ~/.config/mpv/script-opts/modernz.conf. Upstream: github.com/Samillion/ModernZ
#
# Only colors, sizing, and the window-chrome/clutter toggles below are
# theme-driven overrides; everything else uses ModernZ's own (already
# refined) defaults. Edit sizes/toggles here; edit colors in the active theme.

# Layout: classic bottom control bar (title, seekbar, one row of controls).
# No top window bar and no window controls (minimize/maximize/close) — arche
# runs mpv fullscreen and does not want window chrome drawn by the OSC.
layout=default
window_top_bar=no
window_controls=no
show_window_title=no
show_title=yes
truncate_title=yes

# Icons: fluent glyphs, filled style, ships in fonts/modernz-icons.ttf.
icon_theme=fluent
icon_style=filled
# NOTE: FONT_SANS is "SF Pro Text", which libass/CoreText cannot resolve on
# a stock Mac (same caveat as platform.macos.conf's osd-font override) — it
# silently falls back to Helvetica there. Not broken, just not the exact
# family; acceptable for OSC chrome text.
font=${FONT_SANS}

# Premium sizing for a Retina fullscreen display: larger than ModernZ's
# tiny default, still restrained. Icons sit a notch below the bar's own
# scale so the control row does not read as oversized next to the seekbar.
scalefullscreen=1.3
scalewindowed=1.05
seekbar_height=large
slider_rounded_corners=yes
playpause_size=30
midbuttons_size=23
sidebuttons_size=21
title_font_size=22
time_font_size=16
tooltip_font_size=14

# Clutter off: no SponsorBlock-adjacent display, no download/browse chrome.
download_button=no
cache_info=no
cache_info_speed=no

# Animation: eased fade in/out instead of an abrupt pop, and a short but
# not instant hide timeout. keep_with_cursor stops the bar from hiding out
# from under the pointer while it rests on the bar; minmousemove filters
# out sub-pixel jitter (trackpad noise) that would otherwise retrigger the
# show animation on a mouse that never really moved. deadzone_hide=timeout
# routes "cursor left the window" through the same fade instead of an
# instant snap. ModernZ has no separate proximity/hover-reveal mode (that
# is a uosc concept) — visibility is driven by these timers only.
fadeduration=200
fadein=yes
hidetimeout=1500
keep_with_cursor=yes
minmousemove=3
deadzone_hide=timeout

# Colors from the active theme (#RRGGBB):
#   accent      = seekbar fill, handle, active/current states
#   fg          = text and icons
#   bg          = OSC backgrounds
osc_color=#${COLOR_BG_NOHASH}
window_title_color=#${COLOR_FG_NOHASH}
window_controls_color=#${COLOR_FG_NOHASH}
windowcontrols_close_hover=#${COLOR_CRITICAL_NOHASH}
windowcontrols_max_hover=#${COLOR_WARN_NOHASH}
windowcontrols_min_hover=#${COLOR_SUCCESS_NOHASH}
title_color=#${COLOR_FG_NOHASH}
time_color=#${COLOR_FG_NOHASH}
chapter_title_color=#${COLOR_FG_MUTED_NOHASH}
cache_info_color=#${COLOR_FG_MUTED_NOHASH}
side_buttons_color=#${COLOR_FG_NOHASH}
middle_buttons_color=#${COLOR_FG_NOHASH}
playpause_color=#${COLOR_FG_NOHASH}
held_element_color=#${COLOR_OVERLAY0_NOHASH}
hover_effect_color=#${COLOR_ACCENT_NOHASH}
seekbarfg_color=#${COLOR_ACCENT_NOHASH}
seekbarbg_color=#${COLOR_BG_SURFACE_NOHASH}
seekbar_cache_color=#${COLOR_OVERLAY0_NOHASH}
seek_handle_color=#${COLOR_ACCENT_NOHASH}
seek_handle_border_color=#${COLOR_ACCENT_ALT_NOHASH}
nibble_color=#${COLOR_OVERLAY0_NOHASH}
nibble_current_color=#${COLOR_ACCENT_NOHASH}
ab_loop_color=#${COLOR_ACCENT_ALT_NOHASH}
thumbnail_box_color=#${COLOR_BG_ALT_NOHASH}
thumbnail_box_outline=#${COLOR_BORDER_NOHASH}
