# mpv's built-in stats.lua (the key-bindings/stats overlay), skinned with
# the arche theme. Rendered by the theme engine into
# ~/.config/mpv/script-opts/stats.conf. Opened with "?" (page 4, active key
# bindings), bound in input.conf.
#
# mpv's defaults (font_size=20, border_size=1.65, near-osd-color text) read
# too small and too thin against arbitrary video on a Retina fullscreen
# display, hence hard to see. Bigger text with a fully opaque, near-black
# outline reads clearly over any footage.
#
# NOTE: stats.lua colors are raw ASS hex in BBGGRR order (byte-swapped, no
# #), not the #RRGGBB the rest of the theme templates use, per mpv's own
# manual. Hence the _BGR variant here instead of _NOHASH.
font_size=30
border_size=2.5
font_color=${COLOR_FG_BGR}
border_color=${COLOR_CRUST_BGR}
alpha=0
